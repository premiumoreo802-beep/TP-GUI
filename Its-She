local TweenService = game:GetService("TweenService")

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

local enabled = false
local useTween = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 170, 0, 255)
frame.Position = UDim2.new(0, 20, 0, 20)
frame.Parent = gui

local function makeBox(y, placeholder, default)
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0, 150, 0, 25)
	box.Position = UDim2.new(0, 10, 0, y)
	box.PlaceholderText = placeholder
	box.Text = default or ""
	box.Parent = frame
	return box
end

local xBox = makeBox(10, "X", "0")
local yBox = makeBox(45, "Y", "0")
local zBox = makeBox(80, "Z", "0")
local intervalBox = makeBox(115, "Interval", "1")
local tweenTimeBox = makeBox(150, "Tween Time", "2")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 150, 0, 30)
button.Position = UDim2.new(0, 10, 0, 185)
button.Text = "Auto: OFF"
button.Parent = frame

local modeButton = Instance.new("TextButton")
modeButton.Size = UDim2.new(0, 150, 0, 30)
modeButton.Position = UDim2.new(0, 10, 0, 220)
modeButton.Text = "Mode: Teleport"
modeButton.Parent = frame

button.MouseButton1Click:Connect(function()
	enabled = not enabled
	button.Text = enabled and "Auto: ON" or "Auto: OFF"
end)

modeButton.MouseButton1Click:Connect(function()
	useTween = not useTween
	modeButton.Text = useTween and "Mode: Tween" or "Mode: Teleport"
end)

while true do
	if enabled then
		local x = tonumber(xBox.Text)
		local y = tonumber(yBox.Text)
		local z = tonumber(zBox.Text)
		local interval = math.max(tonumber(intervalBox.Text) or 1, 0)
		local tweenTime = math.max(tonumber(tweenTimeBox.Text) or 2, 0)

		if x and y and z then
			local target = CFrame.new(x, y, z)

			if useTween then
				local tween = TweenService:Create(
					hrp,
					TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
					{CFrame = target}
				)
				tween:Play()
				tween.Completed:Wait()
			else
				hrp.CFrame = target
			end
		end

		task.wait(interval)
	else
		task.wait(0.1)
	end
end
