-- Button Hover Effect
button.MouseEnter:Connect(function()
    if loopEnabled then
        button.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 255, 150)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 200, 100))
        })
        buttonStroke.Color = Color3.fromRGB(200, 255, 200)
    else
        button.BackgroundColor3 = Color3.fromRGB(100, 180, 255)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 200, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 150, 255))
        })
        buttonStroke.Color = Color3.fromRGB(200, 220, 255)
    end
end)

button.MouseLeave:Connect(function()
    if loopEnabled then
        button.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 200, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 150, 50))
        })
        buttonStroke.Color = Color3.fromRGB(150, 255, 150)
    else
        button.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 150, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 100, 200))
        })
        buttonStroke.Color = Color3.fromRGB(150, 200, 255)
    end
end)

-- Button Click - Toggle Loop
button.MouseButton1Click:Connect(function()
    loopEnabled = not loopEnabled
    button.Text = loopEnabled and "🚀 LOOP: ON" or "LOOP: OFF"
    
    if loopEnabled then
        button.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 200, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 150, 50))
        })
        buttonStroke.Color = Color3.fromRGB(150, 255, 150)
    else
        button.BackgroundColor3 = Color3.fromRGB(50, 100, 200)
        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 150, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 100, 200))
        })
        buttonStroke.Color = Color3.fromRGB(150, 200, 255)
    end
end)

-- TELEPORT LOOP
task.spawn(function()
    while true do
        if loopEnabled then
            local x, y, z = box.Text:match("^%s*(-?[%d%.]+)%s*,%s*(-?[%d%.]+)%s*,%s*(-?[%d%.]+)%s*$")
            
            if x and y and z then
                hrp.CFrame = CFrame.new(tonumber(x), tonumber(y), tonumber(z))
            end
        end
        
        task.wait(0.1)
    end
end)
