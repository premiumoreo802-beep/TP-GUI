local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")

local enabled = false
local useTween = false
local isMinimized = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "TeleportGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Main Menu Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 170, 0, 300)
frame.Position = UDim2.new(0, 20, 0, 20)
frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
frame.BorderSizePixel = 0
frame.Parent = gui

local minButton = Instance.new("TextButton")
minButton.Size = UDim2.new(0, 30, 0, 30)
minButton.Position = UDim2.new(1, 5, 0, 0)
minButton.Text = "" 
minButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
minButton.BorderSizePixel = 0
minButton.Parent = frame

local function makeBox(y, placeholder, default)
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0, 150, 0, 25)
	box.Position = UDim2.new(0, 10, 0, y)
	box.PlaceholderText = placeholder
	box.Text = default or ""
	box.Parent = frame
	return box
end

local xBox = makeBox(10, "X", "0")
local yBox = makeBox(45, "Y", "0")
local zBox = makeBox(80, "Z", "0")
local intervalBox = makeBox(115, "Interval", "1")
local tweenTimeBox = makeBox(150, "Tween Time", "2")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 150, 0, 30)
button.Position = UDim2.new(0, 10, 0, 185)
button.Text = "Auto: OFF"
button.Parent = frame

local modeButton = Instance.new("TextButton")
modeButton.Size = UDim2.new(0, 150, 0, 30)
modeButton.Position = UDim2.new(0, 10, 0, 220)
modeButton.Text = "Mode: Teleport"
modeButton.Parent = frame

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 150, 0, 35)
label.Position = UDim2.new(0, 10, 0, 255)
label.TextScaled = true
label.Text = "X: 0 Y: 0 Z: 0"
label.Parent = frame

-- Toggle GUI Visibility Logic
minButton.MouseButton1Click:Connect(function()
	isMinimized = not isMinimized
	
	-- Toggle visibility of all internal components
	xBox.Visible = not isMinimized
	yBox.Visible = not isMinimized
	zBox.Visible = not isMinimized
	intervalBox.Visible = not isMinimized
	tweenTimeBox.Visible = not isMinimized
	button.Visible = not isMinimized
	modeButton.Visible = not isMinimized
	label.Visible = not isMinimized
	
	if isMinimized then
		frame.Size = UDim2.new(0, 0, 0, 30)        -- Shrink frame to hide body
		frame.BackgroundTransparency = 1          -- Hide frame box entirely
		minButton.Position = UDim2.new(0, 0, 0, 0) -- Move button to base position
	else
		frame.Size = UDim2.new(0, 170, 0, 300)    -- Restore frame size
		frame.BackgroundTransparency = 0          -- Restore frame background
		minButton.Position = UDim2.new(1, 5, 0, 0) -- Snap button back to top right
	end
end)

button.MouseButton1Click:Connect(function()
	enabled = not enabled
	button.Text = enabled and "Auto: ON" or "Auto: OFF"
end)

modeButton.MouseButton1Click:Connect(function()
	useTween = not useTween
	modeButton.Text = useTween and "Mode: Tween" or "Mode: Teleport"
end)

player.CharacterAdded:Connect(function(char)
	character = char
	hrp = character:WaitForChild("HumanoidRootPart")
end)

task.spawn(function()
	while true do
		local pos = hrp.Position
		label.Text = string.format(
			"X: %.1f\nY: %.1f\nZ: %.1f",
			pos.X, pos.Y, pos.Z
		)
		task.wait(0.1)
	end
end)

while true do
	if enabled then
		local x = tonumber(xBox.Text)
		local y = tonumber(yBox.Text)
		local z = tonumber(zBox.Text)
		local interval = math.max(tonumber(intervalBox.Text) or 1, 0)
		local tweenTime = math.max(tonumber(tweenTimeBox.Text) or 2, 0)

		if x and y and z then
			local target = CFrame.new(x, y, z)

			if useTween then
				local tween = TweenService:Create(
					hrp,
					TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
					{CFrame = target}
				)
				tween:Play()
				tween.Completed:Wait()
			else
				hrp.CFrame = target
			end
		end

		task.wait(interval)
	else
		task.wait(0.1)
	end
end
